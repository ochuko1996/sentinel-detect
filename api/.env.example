# Copy to .env and adjust. All variables are optional; see config/settings.py for defaults.

SENTINEL_ENVIRONMENT=development
SENTINEL_DEBUG=true
SENTINEL_HOST=0.0.0.0
SENTINEL_PORT=8000

# Database: SQLite by default, switch to Postgres by changing the URL and
# installing the 'postgres' extra (uv sync --extra postgres).
SENTINEL_DATABASE__URL=sqlite+aiosqlite:///./data/sentinel.db
# SENTINEL_DATABASE__URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
# SENTINEL_DATABASE__ECHO=false
# SENTINEL_DATABASE__POOL_SIZE=5

SENTINEL_STORAGE__BACKEND=local
SENTINEL_STORAGE__LOCAL_PATH=./data/storage

SENTINEL_SECURITY__JWT_SECRET=change-me-in-production
# SENTINEL_SECURITY__JWT_ALGORITHM=HS256
# SENTINEL_SECURITY__JWT_EXPIRE_MINUTES=60
# SENTINEL_SECURITY__API_KEY_HEADER=X-API-Key
SENTINEL_SECURITY__RATE_LIMIT_PER_MINUTE=120

# Browser origins allowed to call this API cross-origin — the
# sentinel-detect-console client (client/) needs this to reach the API from
# the browser. Empty list disables CORSMiddleware entirely.
SENTINEL_SECURITY__CORS_ORIGINS=["http://localhost:3000"]

# Unset by default — no admin account is created until you set this. See
# "Authentication" in README.md.
# SENTINEL_SECURITY__BOOTSTRAP_ADMIN_USERNAME=admin
# SENTINEL_SECURITY__BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# Static pre-shared keys accepted on X-API-Key as an alternative to a JWT,
# for service/machine callers. Empty by default (no key grants access).
# SENTINEL_SECURITY__API_KEYS=["a-long-random-service-key"]

SENTINEL_MODELS__DEVICE=auto
SENTINEL_MODELS__WEIGHTS_DIR=./data/weights

# weapon/fire/smoke/ppe need fine-tuned weights nobody ships for free; drop a
# real .pt file at data/weights/<name>.pt, then enable the detector below.
# SENTINEL_MODELS__WEIGHTS__YOLOV11N_WEAPON=weapon.pt
# SENTINEL_MODELS__WEIGHTS__YOLOV11N_FIRE=fire.pt
# SENTINEL_MODELS__WEIGHTS__YOLOV11N_SMOKE=smoke.pt
# SENTINEL_MODELS__WEIGHTS__YOLOV11N_PPE=ppe.pt

# ByteTracker tuning (defaults are reasonable for most footage):
# SENTINEL_TRACKING__MAX_AGE=30
# SENTINEL_TRACKING__MIN_HITS=3
# SENTINEL_TRACKING__IOU_THRESHOLD=0.3
# SENTINEL_TRACKING__SECOND_STAGE_IOU_THRESHOLD=0.2
# SENTINEL_TRACKING__HIGH_CONFIDENCE_THRESHOLD=0.6

# Streaming/performance tuning — applies to POST /detect/video and every
# live stream started via POST /detect/stream:
# SENTINEL_PIPELINE__FRAME_SKIP=0     # process 1 of every (frame_skip + 1) frames
# SENTINEL_PIPELINE__MAX_FPS=15       # throttle processing rate; unset = as fast as possible

SENTINEL_LOGGING__LEVEL=INFO
SENTINEL_LOGGING__JSON_FORMAT=true

# Per-detector overrides, e.g.:
# SENTINEL_DETECTORS__WEAPON__ENABLED=true
# SENTINEL_DETECTORS__WEAPON__CONFIDENCE_THRESHOLD=0.6
# SENTINEL_DETECTORS__ANIMAL__ENABLED=false

# Per-event-rule overrides, e.g.:
# SENTINEL_EVENTS__LOITERING__PARAMS__DWELL_SECONDS=120
# SENTINEL_EVENTS__CROWD_DETECTED__PARAMS__MIN_COUNT=10
# SENTINEL_EVENTS__WEAPON_DETECTED__COOLDOWN_SECONDS=0
# SENTINEL_EVENTS__OBJECT_ABANDONED__ENABLED=false

# rest/websocket alert channels work with zero config. webhook/email need
# real external config, so they default to disabled:
# SENTINEL_ALERTS__WEBHOOK__ENABLED=true
# SENTINEL_ALERTS__WEBHOOK__PARAMS__URL=https://example.com/hook
# SENTINEL_ALERTS__WEBHOOK__PARAMS__TIMEOUT_SECONDS=5.0
#
# SENTINEL_ALERTS__EMAIL__ENABLED=true
# SENTINEL_ALERTS__EMAIL__PARAMS__SMTP_HOST=smtp.example.com
# SENTINEL_ALERTS__EMAIL__PARAMS__SMTP_PORT=587
# SENTINEL_ALERTS__EMAIL__PARAMS__USE_TLS=true
# SENTINEL_ALERTS__EMAIL__PARAMS__USERNAME=alerts@example.com
# SENTINEL_ALERTS__EMAIL__PARAMS__PASSWORD=change-me
# SENTINEL_ALERTS__EMAIL__PARAMS__FROM_ADDR=alerts@example.com
# SENTINEL_ALERTS__EMAIL__PARAMS__TO_ADDRS=ops@example.com,security@example.com
#
# SENTINEL_ALERTS__REST__PARAMS__MAX_STORED=1000
